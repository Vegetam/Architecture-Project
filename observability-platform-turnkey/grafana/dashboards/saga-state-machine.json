{
  "title": "Saga State Machine",
  "uid": "saga-state-machine",
  "tags": ["observability-platform", "saga"],
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 38,
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "title": "Sagas Started (last hour)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(saga_started_total[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }
      }
    },
    {
      "title": "Sagas Completed",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(saga_completed_total[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "unit": "short"
        }
      }
    },
    {
      "title": "Sagas Failed / Compensating",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(saga_failed_total[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Compensation Rate (%)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(saga_failed_total[5m])) / sum(rate(saga_started_total[5m])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "title": "P99 Saga Duration",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(saga_duration_seconds_bucket[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Saga Throughput by Name",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(saga_started_total[5m])) by (sagaName)",
          "legendFormat": "{{sagaName}} — started"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(saga_completed_total[5m])) by (sagaName)",
          "legendFormat": "{{sagaName}} — completed"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(saga_failed_total[5m])) by (sagaName)",
          "legendFormat": "{{sagaName}} — failed"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Saga Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(saga_duration_seconds_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "COMPENSATION_FAILED Sagas (needs manual intervention)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\"saga.*\"} |= \"COMPENSATION_FAILED\" | json",
          "legendFormat": ""
        }
      ]
    }
  ]
}
