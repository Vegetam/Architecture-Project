# ------------------------------------------------------------------------------
# Observability Platform — Environment Variables
# Copy this file to .env and CHANGE ALL secrets before running in any real env.
# ------------------------------------------------------------------------------

# Generic
ENVIRONMENT=production

# Kong DB credentials
KONG_PG_DATABASE=kong
KONG_PG_USER=kong
KONG_PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Grafana admin (do NOT use admin/admin)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Alertmanager notification receivers
# Set the channels you actually use; leave others blank to disable them.
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#observability-alerts
PAGERDUTY_ROUTING_KEY=
ALERTMANAGER_EMAIL_TO=

# Optional: Grafana SMTP (for alerting/notifications)
GF_SMTP_ENABLED=false
GF_SMTP_HOST=
GF_SMTP_USER=
GF_SMTP_PASSWORD=
GF_SMTP_FROM_ADDRESS=
GF_SMTP_FROM_NAME=

# ------------------------------------------------------------------------------
# Kubernetes install helper env vars (k8s/scripts/*.sh)
# ------------------------------------------------------------------------------

# MinIO credentials (dev/test only — set strong values, min 16 chars for password)
MINIO_ROOT_USER=minio-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_16CHARS

# Stack namespace
NAMESPACE=observability

# Sizing
PROFILE=small   # small|medium|large

# Provider
PROVIDER=minio  # minio|aws|gcp|azure

# Auth mode
AUTH_MODE=static # static|cloud

# --- AWS (IRSA recommended) ---
AWS_REGION=eu-central-1
S3_ENDPOINT=s3.amazonaws.com
S3_REGION=eu-central-1
S3_FORCE_PATH_STYLE=false
S3_INSECURE=false

# Buckets (Terraform outputs in k8s/infra/aws)
LOKI_S3_BUCKET_CHUNKS=
LOKI_S3_BUCKET_RULER=
LOKI_S3_BUCKET_ADMIN=
TEMPO_S3_BUCKET=
VELERO_BUCKET=

# IRSA role (Terraform output: irsa_role_arn)
AWS_IRSA_ROLE_ARN=

# --- GCP (Workload Identity recommended) ---
LOKI_GCS_BUCKET=
TEMPO_GCS_BUCKET=
# Shared GSA email (Terraform output: gsa_email)
GCP_GSA_EMAIL=

# --- Azure (Workload Identity recommended) ---
AZURE_RESOURCE_GROUP=
AZURE_STORAGE_ACCOUNT=
LOKI_AZURE_CONTAINER_CHUNKS=loki
LOKI_AZURE_CONTAINER_RULER=loki
LOKI_AZURE_CONTAINER_ADMIN=loki
TEMPO_AZURE_CONTAINER=tempo
VELERO_BUCKET=velero
# Managed identity client id (Terraform output: azure_client_id)
AZURE_CLIENT_ID=
