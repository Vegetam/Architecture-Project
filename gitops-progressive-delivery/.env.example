# ------------------------------------------------------------------------------
# GitOps Progressive Delivery — Environment Variables
# Copy to .env and fill in real values before running scripts.
# Never commit .env to git.
# ------------------------------------------------------------------------------

# ArgoCD hostname (used in Ingress + TLS cert)
ARGOCD_HOSTNAME=argocd.your-domain.com

# Kubernetes context to bootstrap
CLUSTER=your-kubecontext

# GitHub Container Registry (for CI image push)
GITHUB_ACTOR=your-github-username

# Notification credentials
SLACK_TOKEN=xoxb-CHANGE_ME
PAGERDUTY_ROUTING_KEY=CHANGE_ME

# GitHub token with repo write access (for CI to update image tags in git)
# Create at: https://github.com/settings/tokens
# Scopes: repo (full)
GITOPS_TOKEN=ghp_CHANGE_ME
